name: str

@html
def Greet(who: str):
    <h1>Hello, {who}!</h1>

@html
def Badge(text: str, color: str = "blue"):
    <span class="badge badge-{color}">{text}</span>

@html
def List(items: list, title: str = "Items"):
    <div class="list-container">
        <h2>{title}</h2>
        if items:
            <ul>
                for item in items:
                    <li>{item}</li>
                end
            </ul>
        else:
            <p>No items</p>
        end
    </div>

def format_name(n: str) -> str:
    return n.upper()

---

<{Greet} who={format_name(name)} />
<{Badge} text="Admin" color="red" />
