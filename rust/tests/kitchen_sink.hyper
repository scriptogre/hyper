# Kitchen sink: exercises every syntax construct for visual IDE smoke testing.
# Open this file in JetBrains after any injection change and verify highlighting.

name: str
count: int = 0
is_active: bool = True
items: list = []
metadata: dict = {}
callback: object = None
style: str = "default"
raw_html: str = ""
value: int = 0
variant: str = "primary"
limit: int = 10
sections: list = []
pairs: list = []
names: list = []
scores: list = []
matrix: list = []

---

########################################
# STATEMENTS
########################################

result = name.upper()
values = [x * 2 for x in range(count)]
lookup = {k: v for k, v in metadata.items()}


########################################
# ELEMENTS
########################################

<div class="container" id="main-{count}" data-name={name}>
    <h1>{name}</h1>
    <p>Count is {count + 1} and active is {is_active}</p>
    <span>{f"Hello, {name}!"}</span>
</div>


########################################
# SELF-CLOSING
########################################

<div>
    <img src="/img/{name}.png" alt={name} />
    <input type="text" value={name} disabled={is_active} />
    <br />
    <hr />
    <meta charset="utf-8" />
    <link rel="stylesheet" href="style.css" />
</div>
<div />
<span />


########################################
# EMPTY ELEMENTS
########################################

<div></div>
<span></span>
<p></p>


########################################
# DEEP NESTING
########################################

<div class="level-1">
    <div class="level-2">
        <div class="level-3">
            <div class="level-4">
                <div class="level-5">
                    <span>Deep content</span>
                </div>
            </div>
        </div>
    </div>
</div>


########################################
# TEXT POSITIONS
########################################

Text before any element
<div>Inside div</div>
Text between elements
<span>Inside span</span>
Text after elements


########################################
# ATTRIBUTES
########################################

<div class="static" id="s-{count}" data-val={name} {is_active} {metadata}>
    Mixed attributes
</div>

# Shorthand
<input {name} {value} {is_active} />
<button {name} {variant} {is_active}>Click</button>
<input type="text" {name} class="input" />

# Spread on HTML
<a {**metadata}>External link</a>
<div id="main" {**metadata} class="container">Content</div>

# Nested braces in attributes
<div class={["card", {"sale": is_active}]}>Product</div>
<div style={{"color": "red", "font": {"size": "12px"}}}>Styled</div>


########################################
# TEMPLATE ATTRIBUTES
########################################

<button class="btn btn-{variant}">Click</button>
<div data-info="{count}-{variant}">Info</div>
<a href="/users/{count}" class="link link-{variant}">Profile</a>
<span data-key="{count}{variant}">Adjacent expressions</span>


########################################
# CLASS LIST AND STYLE DICT
########################################

class_ = ["btn", "btn-primary", {"active": is_active}]
<button {class_}>Class list</button>

styles = {"color": "red", "font-weight": "bold"}
<p {styles}>Styled</p>


########################################
# DATA AND ARIA
########################################

data = {"user-id": 123, "role": "admin"}
aria = {"label": "Close", "hidden": is_active}
<div {data} {aria}>Data and aria</div>


########################################
# RESERVED KEYWORDS
########################################

type_ = "button"
<button class={class_} type={type_}>Reserved keywords</button>


########################################
# BOOLEAN ATTRIBUTES
########################################

<button disabled={is_active}>Submit</button>
<input type="checkbox" checked />
<input type="checkbox" disabled />


########################################
# SAFE HELPER
########################################

{safe(raw_html)}
<div>{safe("<b>bold</b>")}</div>


########################################
# IF / ELIF / ELSE
########################################

if is_active:
    <span class="active">Active</span>
elif count > 0:
    <span class="partial">Partial ({count})</span>
else:
    <span class="inactive">Inactive</span>
end


########################################
# FOR LOOP
########################################

for item in items:
    <li class="item">{item}</li>
end


########################################
# FOR DESTRUCTURING
########################################

for key, val in metadata.items():
    <dt>{key}</dt>
    <dd>{val}</dd>
end


########################################
# WHILE LOOP
########################################

while count > 0:
    <p>Counting down: {count}</p>
    count = count - 1
end


########################################
# MATCH / CASE
########################################

match style:
    case "bold":
        <strong>{name}</strong>
    case "italic":
        <em>{name}</em>
    case _:
        <span>{name}</span>
end


########################################
# TRY / EXCEPT / ELSE / FINALLY
########################################

try:
    <span>{metadata['key']}</span>
except KeyError as e:
    <span>Missing: {e}</span>
except ValueError:
    <span>Bad value</span>
else:
    <span>Success</span>
finally:
    <span>Done</span>
end


########################################
# WITH
########################################

with open("/dev/null") as f:
    <pre>{f.read()}</pre>
end


########################################
# DEFINITIONS
########################################

@fragment
def Badge(text: str, badge_variant: str = "info"):
    <span class="badge badge-{badge_variant}">{text}</span>
end

@cache
@fragment
def CachedList(entries: list):
    <ul>
        for entry in entries:
            <li>{entry}</li>
        end
    </ul>
end

@fragment(name="card")
def Card(title: str):
    <div class="card">
        <h2>{title}</h2>
        {...}
    </div>
end

def format_name(n: str) -> str:
    return n.upper()
end

{Badge("New")}
{CachedList(items)}


########################################
# COMPONENTS
########################################

<{Badge} text="Sale" badge_variant="danger" />
<{Badge} />
<{Badge} {is_active} />
<{Badge} text={format_name(name)} />

<{CachedList} entries={items}>
    <p>Fallback content</p>
</{CachedList}>

<{callback} />


########################################
# SLOTS
########################################

<{...header}>
    <h2>Default Header</h2>
</{...header}>

<{...sidebar}>
    <nav>Default Nav</nav>
</{...sidebar}>

{...}


########################################
# NESTED CONTROL FLOW
########################################

<section>
    if is_active:
        for item in items:
            <{Badge} text={item} />
            <div class="wrapper">
                match item:
                    case "special":
                        <{CachedList} entries={[item, item]} />
                    case _:
                        <span>{item}</span>
                end
            </div>
        end
    end
</section>


########################################
# BREAK / CONTINUE
########################################

<ul>
    for item in items:
        if item == "stop":
            break
        end
        <li>{item}</li>
    end
</ul>

<ul>
    for item in items:
        if item.startswith("_"):
            continue
        end
        <li>{item}</li>
    end
</ul>

c = 0
while True:
    if c >= limit:
        break
    end
    <span>{c}</span>
    c = c + 1
end


########################################
# LOOP PATTERNS
########################################

for i, item in enumerate(items):
    <li data-index="{i}">{item}</li>
end

for num, item in enumerate(items, start=1):
    <li value="{num}">{item}</li>
end

for key, val in pairs:
    <dt>{key}</dt>
    <dd>{val}</dd>
end

for n, score in zip(names, scores):
    <td>{n}</td><td>{score}</td>
end

for row in matrix:
    <tr>
        for cell in row:
            <td>{cell}</td>
        end
    </tr>
end

for i in range(5):
    <li>Item {i}</li>
end

for item in reversed(items):
    <li>{item}</li>
end


########################################
# MATCH GUARDS
########################################

match value:
    case x if x < 0:
        <span>Negative: {x}</span>
    case x if x == 0:
        <span>Zero</span>
    case x if x > 100:
        <span>Large: {x}</span>
    case x:
        <span>Normal: {x}</span>
end

match metadata:
    case {"type": "user", "admin": True}:
        <span>Admin user</span>
    case {"type": "user", "admin": False}:
        <span>Regular user</span>
    case {"type": t} if t.startswith("system"):
        <span>System: {t}</span>
    case _:
        <span>Unknown</span>
end


########################################
# TRY VARIANTS
########################################

try:
    <span>{callback()}</span>
except ValueError as e:
    <span>Value error: {e}</span>
except TypeError as e:
    <span>Type error: {e}</span>
except Exception as e:
    <span>Unknown error: {e}</span>
end

try:
    result = metadata['key']
except KeyError:
    <span>Missing</span>
else:
    <span>Found: {result}</span>
end

try:
    <span>{metadata['value']}</span>
except:
    <span>Error</span>
finally:
    <span>Cleanup</span>
end


########################################
# EMPTY BLOCKS
########################################

if is_active:
end

if is_active:
    <span>Yes</span>
else:
end

for item in items:
end

match is_active:
    case True:
    case False:
        <span>False</span>
end

def empty():
end


########################################
# COMPLEX NESTING
########################################

<div class="container">
    if is_active:
        for section in sections:
            <section id="section-{section['id']}">
                match section['type']:
                    case "header":
                        <h1>{section['title']}</h1>
                    case "list":
                        <ul>
                            for item in section['items']:
                                if item.get('active'):
                                    <li class="active">{item['name']}</li>
                                else:
                                    <li>{item['name']}</li>
                                end
                            end
                        </ul>
                    case _:
                        <div>Unknown type</div>
                end
            </section>
        end
    else:
        <p>Content hidden</p>
    end
</div>


########################################
# EXPRESSIONS
########################################

<span>{metadata['key']}</span>
<span>{metadata.get('key', 'default')}</span>
<span>{name.strip().upper()}</span>
<span>{', '.join(items)}</span>
<span>{'yes' if count > 0 else 'no'}</span>
<span>{count * 2 + 1}</span>
<span>{items[0]}</span>
<span>{items[1:3]}</span>
<span>{len(items)}</span>
<span>{count:03d}</span>
<span>{3.14159:.2f}</span>


########################################
# COMPREHENSIONS
########################################

<span>{[x * 2 for x in range(5)]}</span>
<span>{[item.upper() for item in items if item]}</span>
<span>{{k: v for k, v in metadata.items()}}</span>
<span>{{x for x in items}}</span>
<span>{sum(x for x in range(10))}</span>


########################################
# ADJACENT EXPRESSIONS
########################################

<p>{name}{count}{is_active}</p>

<span>{count} {"item" if count == 1 else "items"}</span>


########################################
# ESCAPED BRACES
########################################

<code>Use {{braces}} in templates</code>
<p>JSON: {{"key": "value"}}</p>
<p>Static {{braces}} and dynamic {name}</p>
<p>{{{{nested}}}}</p>


########################################
# NESTED ELEMENTS
########################################

<div>
    <ul>
        <li>
            <a href="/item/{name}">
                <span class="label">{name}</span>
            </a>
        </li>
    </ul>
</div>


########################################
# KEYWORDS AS CONTENT
########################################

<p>for example, this is just text</p>
<div>if you think about it, this makes sense</div>
<span>while we wait, have some tea</span>
<article>try our new product today</article>
<p>match the following pairs</p>
<blockquote>with great power comes great responsibility</blockquote>
<p>def initely the best approach</p>


########################################
# PYTHON FEATURES
########################################

if (n := len(items)) > 0:
    <span>Found {n} items</span>
end

sorter = lambda x: x.lower()
first, *rest = items
merged = {**metadata, "extra": "value"}
<span>{"positive" if value > 0 else "zero" if value == 0 else "negative"}</span>
<span>{value=}</span>
<span>{items!r}</span>


########################################
# UNICODE
########################################

<span>Hello 👋</span>
<span>Stars: ⭐⭐⭐</span>
<p lang="zh">你好世界</p>
<p lang="ja">こんにちは</p>
<p dir="rtl" lang="ar">مرحبا بالعالم</p>
<span>Arrows: ← → ↑ ↓</span>
<span>Math: ∞ ≠ ≤ ≥ ± × ÷</span>


########################################
# HTML ENTITIES
########################################

<p>&lt;script&gt; is escaped</p>
<p>Copyright: &copy; 2024</p>
<p>&#60;angle brackets&#62;</p>
<p>&copy; {2024} All rights reserved</p>


########################################
# COMMENTS
########################################

# Top-level comment
<div>
    # Indented comment
    <span>Text</span>  # Trailing comment
</div>
<th scope="col">#</th>
<a href="#section">Jump</a>
<div style="color: #ff0000">Red</div>
<span>{name or '#'}</span>
<p>Text # with hash # multiple # times</p>


########################################
# WHITESPACE
########################################

<div>After blank lines</div>

<span>Between blank lines</span>
