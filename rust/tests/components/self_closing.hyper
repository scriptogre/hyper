name: str
on_click: Callable
disabled: bool

---

# Simple self-closing
<{Button} />

# With attributes
<{Button} label="Click me" />

# With expression attributes
<{Button} label={name} on_click={on_click} />

# With shorthand
<{Button} {disabled} />

# Mixed
<{Icon} name="star" size={24} {disabled} />
