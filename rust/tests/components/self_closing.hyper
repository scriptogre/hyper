label: str
disabled: bool
variant: str = "primary"

---

# Simple self-closing
<{Button} />

# With static attribute
<{Button} label="Click me" />

# With expression attributes
<{Button} label={label} variant={variant} />

# With shorthand
<{Button} {disabled} />

# Mixed
<{Icon} name="star" size={24} {disabled} />
