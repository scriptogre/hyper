on_sale: bool
variant: str

---

# Dict in class attribute
<div class={["card", {"sale": on_sale}]}>
    <span>Product</span>
</div>

# Nested dict in style attribute
<div style={{"color": "red", "font": {"size": "12px"}}}>
    Styled
</div>

# Set literal in expression
<span>{frozenset({1, 2, 3})}</span>

# Dict comprehension in attribute
<div data={"{k: v for k, v in items.items()}"}>
    Mapped
</div>
